{
  "__comment__": [
    "CodeChecker analyzer profile for the thesis padding-leak prototype.",
    "",
    "Usage:",
    "  1. Build the plugin:  bash scripts/build.sh",
    "  2. Set the plugin path in the environment:",
    "       export PLUGIN_PATH=/absolute/path/to/build/SecurityMiscPlugin.so",
    "  3. Create a tidyargs file:",
    "       echo \"-load $PLUGIN_PATH -checks=-*,security-misc-padding-boundary-leak\" > /tmp/tidy_args.txt",
    "  4. Run analysis:",
    "       CodeChecker analyze compile_commands.json \\",
    "         --config codechecker.json \\",
    "         --analyzer-config clang-tidy:cc-verbatim-args-file=/tmp/tidy_args.txt \\",
    "         -o ./cc-results",
    "  5. Parse results:",
    "       CodeChecker parse ./cc-results",
    "",
    "NOTE: The run_codechecker.sh script handles steps 2-5 automatically.",
    "This file documents the CodeChecker configuration options used."
  ],
  "analyze": [
    "--analyzers", "clang-tidy",
    "--jobs", "4",
    "--output", "./cc-results"
  ],
  "parse": [
    "--trim-path-prefix", "."
  ]
}
